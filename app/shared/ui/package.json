{
  "name": "@crate/ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/lib/cn.js",
  "types": "./dist/lib/cn.d.ts",
  "files": [
    "dist",
    "tokens"
  ],
  "sideEffects": [
    "tokens/*.css"
  ],
  "exports": {
    "./tokens/*": "./tokens/*",
    "./lib/*": {
      "types": "./lib/*.ts",
      "default": "./lib/*.ts"
    },
    "./primitives/*": {
      "types": "./primitives/*.tsx",
      "default": "./primitives/*.tsx"
    },
    "./shadcn/*": {
      "types": "./shadcn/*.tsx",
      "default": "./shadcn/*.tsx"
    },
    "./composites/*": {
      "types": "./composites/*.tsx",
      "default": "./composites/*.tsx"
    },
    "./domain/*": {
      "types": "./domain/*.tsx",
      "default": "./domain/*.tsx"
    },
    "./charts/*": {
      "types": "./charts/*.ts",
      "default": "./charts/*.ts"
    }
  },
  "publishConfig": {
    "exports": {
      "./tokens/*": "./tokens/*",
      "./lib/*": {
        "types": "./dist/lib/*.d.ts",
        "default": "./dist/lib/*.js"
      },
      "./primitives/*": {
        "types": "./dist/primitives/*.d.ts",
        "default": "./dist/primitives/*.js"
      },
      "./shadcn/*": {
        "types": "./dist/shadcn/*.d.ts",
        "default": "./dist/shadcn/*.js"
      },
      "./composites/*": {
        "types": "./dist/composites/*.d.ts",
        "default": "./dist/composites/*.js"
      },
      "./domain/*": {
        "types": "./dist/domain/*.d.ts",
        "default": "./dist/domain/*.js"
      },
      "./charts/*": {
        "types": "./dist/charts/*.d.ts",
        "default": "./dist/charts/*.js"
      }
    },
    "main": "./dist/lib/cn.js",
    "types": "./dist/lib/cn.d.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": ">=0.400.0",
    "radix-ui": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "tsup": "^8.5.1",
    "vitest": "^4.1.4"
  }
}
