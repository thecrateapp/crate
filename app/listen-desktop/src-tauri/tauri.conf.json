{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crate",
  "version": "0.1.0",
  "identifier": "app.cratemusic.crate.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5178",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "label": "main",
        "title": "Crate",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["cratemusic"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Crate",
    "homepage": "https://cratemusic.app",
    "category": "Music",
    "shortDescription": "Crate desktop music player",
    "longDescription": "Desktop client for Crate, the self-hosted music platform.",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "section": "sound",
        "desktopTemplate": "linux/desktop-template.desktop"
      },
      "rpm": {
        "desktopTemplate": "linux/desktop-template.desktop"
      }
    }
  }
}
