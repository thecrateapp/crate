# Crate Configuration
TZ=Europe/Madrid
PUID=1000
PGID=1000
DOMAIN=example.com
CRATE_CORS_EXTRA_ORIGINS=
LANGUAGE=es
CRATE_IMAGE_REGISTRY=ghcr.io
CRATE_IMAGE_OWNER=thecrateapp
CRATE_IMAGE_TAG=latest

# Directories
DATA_DIR=./data
MEDIA_DIR=./media
MUSIC_DIR=./media/music
DOWNLOADS_DIR=./media/downloads/soulseek
CRATE_CONFIG_FILE=./app/config.yaml

# Ports
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TIDARR_PORT=8484
SLSKD_PORT=5030
SLSKD_LISTEN_PORT=50300
CRATE_API_PORT=8585
CRATE_UI_PORT=8580
NGINX_PORT=8090

# Cloudflare
CF_DNS_API_TOKEN=

# Service credentials
TIDARR_PASSWORD=
SLSKD_API_KEY=
SLSKD_SLSK_USERNAME=
SLSKD_SLSK_PASSWORD=
PROTONVPN_USER=
PROTONVPN_PASS=

# External APIs
LASTFM_APIKEY=
LASTFM_API_SECRET=
FANART_API_KEY=
SPOTIFY_ID=
SPOTIFY_SECRET=
SETLISTFM_API_KEY=
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
TICKETMASTER_API_KEY=
TIDAL_COUNTRY_CODE=ES

# LLM providers
LLM_PROVIDER=ollama/llama3.1:8b
OLLAMA_URL=http://ollama:11434
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# PostgreSQL superuser bootstrap
POSTGRES_SUPERUSER_USER=crate
POSTGRES_SUPERUSER_PASSWORD=
POSTGRES_SUPERUSER_DB=crate

# PostgreSQL app user
CRATE_POSTGRES_USER=crate
CRATE_POSTGRES_PASSWORD=
CRATE_POSTGRES_DB=crate

# Auth
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
DEFAULT_ADMIN_PASSWORD=admin

# Read plane
READPLANE_ENABLED=true
READPLANE_ENABLE_SSE=true
READPLANE_ROUTE_MODE=shadow
READPLANE_FALLBACK_ENABLED=true
READPLANE_MAX_DB_CONNS=8
READPLANE_MIN_DB_CONNS=1
READPLANE_QUERY_TIMEOUT_MS=800
READPLANE_SNAPSHOT_MAX_AGE_SECONDS=600
READPLANE_STALE_MAX_AGE_SECONDS=3600

# Media/download workers
CRATE_MEDIA_WORKER_MAX_ACTIVE=1
STREAM_TRANSCODE_MAX_CONCURRENT=1
CRATE_SSE_REDIS_MAX_CONNECTIONS=128

# Background backpressure
CRATE_RESOURCE_GOVERNOR_ENABLED=true
CRATE_RESOURCE_MAX_LOAD_RATIO=0.85
CRATE_RESOURCE_MAX_IOWAIT_PERCENT=25
CRATE_RESOURCE_MAX_SWAP_PERCENT=30
CRATE_RESOURCE_MIN_SWAP_USED_MB=512
CRATE_RESOURCE_MIN_MEMORY_AVAILABLE_PERCENT=15
CRATE_RESOURCE_MAX_ACTIVE_USERS=0
CRATE_RESOURCE_MAX_ACTIVE_STREAMS=0
CRATE_RESOURCE_DEFER_SECONDS=300
CRATE_MAINTENANCE_WINDOW_ENABLED=true
CRATE_MAINTENANCE_WINDOW_START=02:00
CRATE_MAINTENANCE_WINDOW_END=07:00
CRATE_MAINTENANCE_WINDOW_FINGERPRINT_LIMIT=1000

# Optional local-dev Soulseek credentials.
# Keep these separate from the main/prod Soulseek account so a local slskd
# does not kick the production instance off the network.
DEV_SLSKD_SLSK_USERNAME=
DEV_SLSKD_SLSK_PASSWORD=
